{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/tooling/cli/schema.json",
  "productName": "CRATE",
  "version": "1.0.0",
  "identifier": "com.crate.desktop",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CRATE",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "binaries/server.mjs",
      "binaries/.env",
      "binaries/db/migrations/*",
      "binaries/db/migrations/meta/*",
      "binaries/node_modules/@libsql/client/**/*",
      "binaries/node_modules/libsql/**/*",
      "binaries/node_modules/@libsql/win32-x64-msvc/**/*"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["crate"]
      }
    },
    "shell": {
      "open": true
    }
  }
}
