# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Spotify OAuth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=crate://auth/spotify/callback

# Beatport (user login — client_id auto-scraped from docs page)
BEATPORT_USERNAME=
BEATPORT_PASSWORD=
BEATPORT_CLIENT_ID=

# SoundCloud
SOUNDCLOUD_CLIENT_ID=

# App
PORT=4242
DATABASE_URL=./crate.db
LIBRARY_ROOT_PATH=~/Music/CRATE
REDIS_URL=redis://localhost:6379

# Feature flags
ENABLE_STEMS=false
ENABLE_DJCITY=false
